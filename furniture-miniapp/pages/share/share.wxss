.share-page {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 56rpx 40rpx 48rpx;
  background:
    linear-gradient(180deg, rgba(255, 253, 248, 0.96), rgba(241, 232, 213, 0.9)),
    #fbf8ef;
}

.hero {
  min-height: 760rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
  border: 1rpx solid rgba(101, 77, 48, 0.18);
  border-radius: 24rpx;
  background: #fffdf8;
  box-shadow: 0 28rpx 72rpx rgba(64, 50, 35, 0.12);
}

.hero-copy {
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  padding: 52rpx 42rpx 20rpx;
}

.eyebrow {
  color: #9b622f;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0;
  text-transform: uppercase;
}

.title {
  color: #2b261f;
  font-size: 58rpx;
  font-weight: 700;
  line-height: 1.1;
  letter-spacing: 0;
}

.summary {
  max-width: 560rpx;
  color: #6c6256;
  font-size: 28rpx;
  line-height: 1.7;
  letter-spacing: 0;
}

.hero-image {
  width: 100%;
  height: 420rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  margin-top: 34rpx;
}

.actions button {
  height: 92rpx;
  border-radius: 14rpx;
  font-size: 30rpx;
  font-weight: 700;
  letter-spacing: 0;
}

.primary-action {
  background: #9b622f !important;
  color: #fffdf8 !important;
}

.secondary-action {
  border: 1rpx solid rgba(101, 77, 48, 0.24);
  background: rgba(255, 253, 248, 0.84);
  color: #2b261f;
}
